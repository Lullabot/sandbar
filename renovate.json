{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "automerge": true,
  "customManagers": [
    {
      "description": "Track the molecule test container image; no built-in manager scans molecule.yml",
      "customType": "regex",
      "managerFilePatterns": ["/^molecule/.+/molecule\\.ya?ml$/"],
      "matchStrings": [
        "image:\\s*[\"']?(?<depName>[^:\"'@\\s]+):(?<currentValue>[^@\"'\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Track the pinned GitLab CLI (glab) release in the dev-tools role",
      "managerFilePatterns": ["/^roles/dev-tools/defaults/main\\.yml$/"],
      "matchStrings": [
        "devtools_glab_version:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "gitlab-org/cli",
      "datasourceTemplate": "gitlab-releases",
      "registryUrlTemplate": "https://gitlab.com",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Track the pinned Drupal.org CLI (drupalorg) PHAR release in the dev-tools role",
      "managerFilePatterns": ["/^roles/dev-tools/defaults/main\\.yml$/"],
      "matchStrings": [
        "devtools_drupalorg_cli_version:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "mglaman/drupalorg-cli",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "description": "Never automerge GitHub Actions updates; require manual review",
      "matchManagers": ["github-actions"],
      "automerge": false
    }
  ]
}
