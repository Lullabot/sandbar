{
  "theme": "auto",
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "direnv export bash > \"$CLAUDE_ENV_FILE\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "direnv export bash > \"$CLAUDE_ENV_FILE\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
