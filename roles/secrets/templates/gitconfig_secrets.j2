{# Rendered into ~/.gitconfig via blockinfile. One stanza per secrets_github
   item: each non-empty scope adds an includeIf that only applies under that
   checkout subtree, pointing at a scope-specific gitconfig include; the
   default (empty scope) sets the VM-wide credential.helper.

   Ordering matters: git's credential subsystem tries configured helpers in
   the order they appear in the resolved config and stops at the first one
   that returns a full username+password, it does NOT prefer a "more
   specific" helper found later. So every scoped includeIf must be emitted
   BEFORE the unconditional default helper -- otherwise the default helper
   (always present, unconditional) would win before git ever reaches the
   scope-specific one. #}
{% for item in _secrets_github_with_slug | default([]) if (item.scope | default('')) | length > 0 %}
[includeIf "gitdir:~/{{ item.scope }}/"]
	path = ~/.config/sandbar/gitconfig.d/{{ item.slug }}
{% endfor %}
{% for item in _secrets_github_with_slug | default([]) if (item.scope | default('')) | length == 0 %}
[credential]
	helper = store --file={{ user_home }}/.config/sandbar/git-credentials/{{ item.slug }}
{% endfor %}
